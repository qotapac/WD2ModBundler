<Window x:Class="WD2ModBundler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WD2ModBundler Terminal" Height="900" Width="670"
        Background="Black"
        Foreground="WhiteSmoke"
        FontFamily="Consolas"
        FontSize="14">

    <Grid Margin="10">
        <StackPanel>
            <!-- 7-Zip Selection -->
            <Button Content="Select 7-Zip.exe" Height="35" Margin="0,0,0,5"
                    Background="#333333" Foreground="WhiteSmoke" BorderBrush="WhiteSmoke" Click="Select7Zip_Click"/>
            <TextBlock Name="SevenZipPathTextBlock" Text="No 7-Zip selected" Margin="0,0,0,10" Foreground="WhiteSmoke"/>

            <!-- Mod Archives Folder -->
            <Button Content="Select folder with mods archives" Height="35" Margin="0,0,0,5"
                    Background="#333333" Foreground="WhiteSmoke" BorderBrush="WhiteSmoke" Click="SelectModFolder_Click"/>
            <TextBlock Name="FolderPathTextBlock" Text="No folder with mods selected" Margin="0,0,0,10" Foreground="WhiteSmoke"/>

            <!-- Patch Tools Folder -->
            <Button Content="Select folder with WD2 Patch Tools" Height="35" Margin="0,0,0,5"
                    Background="#333333" Foreground="WhiteSmoke" BorderBrush="WhiteSmoke" Click="SelectPatchTools_Click"/>
            <TextBlock Name="PatchToolsPath" Text="No folder with WD2 Patch Tools selected" Margin="0,0,0,10" Foreground="WhiteSmoke"/>

            <!-- Combine Mods Button -->
            <Button Content="Combine Mods" Height="35" Margin="0,10,0,10"
                    Background="#333333" Foreground="WhiteSmoke" BorderBrush="WhiteSmoke" Click="CombineMods_Click"/>

            <!-- Music Controls -->
            <Border BorderBrush="WhiteSmoke" BorderThickness="1" Padding="4" Margin="0,3,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- MUSIC label (left side) -->
                    <TextBlock Text="MUSIC"
                               Grid.Row="0"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="WhiteSmoke"/>

                    <!-- Play / Stop buttons (right side) -->
                    <StackPanel Orientation="Horizontal"
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Right">

                        <Button Content="▶"
                                FontSize="10"
                                Width="20"
                                Height="18"
                                Padding="0"
                                Margin="2,0"
                                Background="#333333"
                                Foreground="WhiteSmoke"
                                BorderBrush="WhiteSmoke"
                                Click="PlayMusic_Click"/>

                        <Button Content="⏹"
                                FontSize="10"
                                Width="20"
                                Height="18"
                                Padding="0"
                                Margin="2,0"
                                Background="#333333"
                                Foreground="WhiteSmoke"
                                BorderBrush="WhiteSmoke"
                                Click="StopMusic_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- Progress Bar -->
            <ProgressBar Name="ProgressBar" Height="10" Minimum="0" Maximum="100" Margin="0,0,0,10"/>

            <!-- Logging / Terminal Output -->
            <TextBox Name="LogTextBox" Height="650" 
                     VerticalScrollBarVisibility="Auto"
                     Background="Black" Foreground="WhiteSmoke"
                     FontFamily="Consolas" FontSize="14"
                     IsReadOnly="True" TextWrapping="Wrap"
                     BorderThickness="1" BorderBrush="WhiteSmoke"/>
        </StackPanel>
    </Grid>
</Window>